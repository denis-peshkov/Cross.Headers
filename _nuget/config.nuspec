<?xml version="1.0"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Cross.Headers</id>
    <version>0.0.0</version>
    <authors>Denis Peshkov</authors>
    <owners>Denis Peshkov</owners>
    <projectUrl>https://github.com/denis-peshkov/Cross.Headers</projectUrl>
    <repository type="git" url="https://github.com/denis-peshkov/Cross.Headers.git" />
    <copyright>Copyright 2026 Denis Peshkov</copyright>
    <license type="expression">MIT</license>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <readme>README.md</readme>
    <icon>icon.png</icon>
    <description>ASP.NET Core middleware boilerplate for handling correlation id, security headers and user context based on configuration and OpenIdConnect authentication.</description>
    <tags>.NET ASP.NET ASP.NETCore Middleware Headers Security CorrelationId CSP OpenIdConnect Configuration UserContext</tags>
    <releaseNotes>
      Fix packages versions.
    </releaseNotes>
    <dependencies>
      <group targetFramework="net6.0">
        <dependency id="Microsoft.AspNetCore.Authentication.OpenIdConnect" version="6.0.25" />
        <dependency id="Microsoft.Extensions.Configuration.Binder" version="8.0.2" />
      </group>
      <group targetFramework="net7.0">
        <dependency id="Microsoft.AspNetCore.Authentication.OpenIdConnect" version="7.0.20" />
        <dependency id="Microsoft.Extensions.Configuration.Binder" version="8.0.2" />
      </group>
      <group targetFramework="net8.0">
        <dependency id="Microsoft.AspNetCore.Authentication.OpenIdConnect" version="8.0.24" />
        <dependency id="Microsoft.Extensions.Configuration.Binder" version="8.0.2" />
      </group>
      <group targetFramework="net9.0">
        <dependency id="Microsoft.AspNetCore.Authentication.OpenIdConnect" version="9.0.13" />
        <dependency id="Microsoft.Extensions.Configuration.Binder" version="9.0.14" />
      </group>
      <group targetFramework="net10.0">
        <dependency id="Microsoft.AspNetCore.Authentication.OpenIdConnect" version="10.0.3" />
        <dependency id="Microsoft.Extensions.Configuration.Binder" version="10.0.5" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="..\Cross.Headers\bin\Release\net6.0\Cross.Headers*.*" target="lib\net6.0" />
    <file src="..\Cross.Headers\bin\Release\net7.0\Cross.Headers*.*" target="lib\net7.0" />
    <file src="..\Cross.Headers\bin\Release\net8.0\Cross.Headers*.*" target="lib\net8.0" />
    <file src="..\Cross.Headers\bin\Release\net9.0\Cross.Headers*.*" target="lib\net9.0" />
    <file src="..\Cross.Headers\bin\Release\net10.0\Cross.Headers*.*" target="lib\net10.0" />
    <file src="..\README.md" target="" />
    <file src="..\icon.png" target="" />
  </files>
</package>
